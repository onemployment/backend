// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("POSTGRES_DB_URL")
}

// ================================
// AUTHENTICATION & USER MODELS
// ================================

model User {
  // Primary identifier
  id           String   @id @default(uuid())

  // Authentication fields
  email        String   @unique @db.VarChar(255)
  username     String   @unique @db.VarChar(50)
  passwordHash String?  @db.VarChar(255) // nullable for OAuth-only users

  // Personal information
  firstName    String   @db.VarChar(100)
  lastName     String   @db.VarChar(100)
  displayName  String?  @db.VarChar(200) // optional, set post-registration

  // OAuth provider linking
  googleId     String?  @unique @db.VarChar(255)

  // Account status
  emailVerified Boolean  @default(false)
  isActive      Boolean  @default(true)

  // Audit trail fields
  accountCreationMethod String  @db.VarChar(20) // "local" or "google"
  lastPasswordChange    DateTime?

  // Timestamps
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastLoginAt  DateTime?

  // Relations
  sourceDocument        SourceDocument?
  careerProfile         CareerProfile?
  personalProfileSource PersonalProfileSource?
  personalProfile       PersonalProfile?
  applications          Application[]

  // Performance indexes
  @@index([email], name: "user_email_idx")
  @@index([username], name: "user_username_idx")
  @@index([createdAt], name: "user_created_at_idx")
  @@index([lastLoginAt], name: "user_last_login_idx")
  @@index([isActive], name: "user_active_idx")
  @@index([accountCreationMethod], name: "user_creation_method_idx")

  @@map("users")
}

model SourceDocument {
  id               String   @id @default(uuid())
  userId           String   @unique
  originalFilename String   @db.VarChar(255)
  storagePath      String   @db.VarChar(500)
  mimeType         String   @db.VarChar(100)
  sizeBytes        Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("source_documents")
}

model CareerProfile {
  id                      String    @id @default(uuid())
  userId                  String    @unique
  extractionStatus        String    @default("not_started") @db.VarChar(20)
  lastExtractedAt         DateTime?
  sourceDocumentId        String?
  experiences             Json      @default("[]")
  education               Json      @default("[]")
  certifications          Json      @default("[]")
  projects                Json      @default("[]")
  skills                  Json      @default("{}")
  professionalDevelopment Json      @default("{}")
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("career_profiles")
}

model PersonalProfileSource {
  id        String   @id @default(uuid())
  userId    String   @unique
  text      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("personal_profile_sources")
}

model PersonalProfile {
  id                   String   @id @default(uuid())
  userId               String   @unique
  professionalIdentity Json     @default("{}")
  coreValues           Json     @default("[]")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("personal_profiles")
}

model Application {
  id             String    @id @default(uuid())
  userId         String
  company        String    @db.VarChar(255)
  roleTitle      String    @db.VarChar(255)
  jobPostingText String
  status         String    @default("draft") @db.VarChar(20)
  analysis       Json      @default("{}")
  appliedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], name: "application_user_id_idx")
  @@index([status], name: "application_status_idx")
  @@map("applications")
}
